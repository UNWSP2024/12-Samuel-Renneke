import tkinter

class Main:
    def __init__(self):
        def checkout():
            cost = 0

            if self.oil_var.get():
                cost += 30
            if self.lube_var.get():
                cost += 20
            if self.radiator_var.get():
                cost += 40
            if self.transmission_var.get():
                cost += 100
            if self.muffler_var.get():
                cost += 200
            if self.tire_var.get():
                cost += 20

            self.result_label.config(text=f"Total cost: ${cost}")
        main_window = tkinter.Tk()
        main_window.title("Maintenance")

        tkinter.Label(main_window,text = "What services would you like?").pack()

        self.oil_var = tkinter.BooleanVar()
        self.lube_var = tkinter.BooleanVar()
        self.radiator_var = tkinter.BooleanVar()
        self.transmission_var = tkinter.BooleanVar()
        self.muffler_var = tkinter.BooleanVar()
        self.tire_var = tkinter.BooleanVar()

        tkinter.Checkbutton(main_window, text="Oil Change - $30.00", variable=self.oil_var).pack()
        tkinter.Checkbutton(main_window, text="Lube Change - $20.00", variable=self.lube_var).pack()
        tkinter.Checkbutton(main_window, text="Radiator Flush - $40.00", variable=self.radiator_var).pack()
        tkinter.Checkbutton(main_window, text="Transmission - $100.00", variable=self.transmission_var).pack()
        tkinter.Checkbutton(main_window, text="Muffler - $200.00", variable=self.muffler_var).pack()
        tkinter.Checkbutton(main_window, text="Tire Rotation - $20.00", variable=self.tire_var).pack()

        checkout = tkinter.Button(main_window,text = "Checkout",command = checkout)
        checkout.pack()

        self.result_label = tkinter.Label(main_window, text="")
        self.result_label.pack()

        quit_button = tkinter.Button(main_window,text = "Quit",command = main_window.destroy)
        quit_button.pack()

        main_window.mainloop()

if __name__ == "__main__":
    main = Main()
