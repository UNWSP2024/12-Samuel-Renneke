import tkinter as tk

class Calculator:

    def __init__(self):
        def calculate():
            try:
                gallons = float(self.gallons_entry.get())
                distance = float(self.distance_entry.get())

                if gallons == 0:
                    self.result_label.config(text="Gallons cannot be zero")
                    return

                mpg = distance / gallons
                self.result_label.config(text=f"{mpg:.2f} miles per gallon")

            except ValueError:
                self.result_label.config(text="Please enter valid numbers")

        self.main_window = tk.Tk()
        self.main_window.title("Car mileage calculator")

        label1 = self.label1 = tk.Label(self.main_window,text = "Enter the amount of gallons the tank can hold: ")
        label1.pack()

        self.gallons_entry = tk.Entry(self.main_window)
        self.gallons_entry.pack()

        label2 = self.label2 = tk.Label(self.main_window,text = "Enter the distance the car can be driven on a full tank in miles: ")
        label2.pack()

        self.distance_entry = tk.Entry(self.main_window)
        self.distance_entry.pack()

        calculate_button = tk.Button(self.main_window, text = "Calculate", command = calculate)
        calculate_button.pack()

        self.result_label = tk.Label(self.main_window, text="")
        self.result_label.pack()

        quit_button = tk.Button(self.main_window, text="Quit", command=self.main_window.destroy)
        quit_button.pack()

        tk.mainloop()
if __name__ == '__main__':
    calculator = Calculator()
